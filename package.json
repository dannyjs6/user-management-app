{
  "name": "vue3-ts-boilerplate",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "serve:mock": "json-server --watch db.json --port 4444 --routes routes.json",
    "start": "concurrently \"npm run dev\" \"npm run serve:mock\"",
    "lint": "eslint . --ext .ts,.vue --fix"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.1",
    "json-server": "^0.17.0",
    "sass": "^1.70.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^1.5.0"
  }
}
